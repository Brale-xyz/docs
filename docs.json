{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Brale",
  "description": "API documentation for issuing, moving, and managing stablecoins on any blockchain with Brale.",
  "colors": {
    "primary": "#000000",
    "light": "#6938EF",
    "dark": "#18181B"
  },
  "favicon": "/favicon.svg",
  "seo": {
    "metatags": {
      "canonical": "https://docs.brale.xyz",
      "og:site_name": "Brale"
    },
    "indexing": "navigable"
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "API Keys",
          "icon": "key",
          "href": "https://app.brale.xyz"
        },
        {
          "anchor": "API Logs",
          "icon": "database",
          "href": "https://app.brale.xyz/api?tab=activity"
        },
        {
          "anchor": "Changelog",
          "icon": "clock-rotate-left",
          "href": "/changelog"
        }
      ]
    },
    "anchors": [
      {
        "anchor": "API status",
        "href": "https://status.brale.xyz/"
      }
    ]
  },
  "logo": {
    "light": "/images/brale/brale-logo-light.svg",
    "dark": "/images/brale/brale-logo-dark.svg"
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.brale.xyz"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/Brale-xyz"
    }
  },
  "openapi": "https://api.brale.xyz/openapi",
  "redirects": [
    {
      "source": "/docs/:slug*",
      "destination": "/documentation/:slug*"
    },
    {
      "source": "/reference/:slug*",
      "destination": "/api-reference/brale/:slug*"
    }
  ]
}
