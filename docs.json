{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Brale",
  "description": "API documentation for issuing, moving, and managing stablecoins on any blockchain with Brale.",
  "colors": {
    "primary": "#000000",
    "light": "#6938EF",
    "dark": "#18181B"
  },
  "favicon": "/favicon.svg",
  "seo": {
    "metatags": {
      "canonical": "https://docs.brale.xyz",
      "og:site_name": "Brale"
    },
    "indexing": "navigable"
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "API Keys",
          "icon": "key",
          "href": "https://app.brale.xyz"
        },
        {
          "anchor": "API Logs",
          "icon": "database",
          "href": "https://app.brale.xyz/api?tab=activity"
        },
        {
          "anchor": "Changelog",
          "icon": "clock-rotate-left",
          "href": "/changelog"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Information",
        "pages": [
          "documentation/introduction",
          "documentation/troubleshooting",
          {
            "group": "API Design",
            "pages": [
              "documentation/api-design/primitives",
              "documentation/api-design/structure",
              "documentation/api-design/example-standard"
            ]
          },
          {
            "group": "Platform",
            "pages": [
              "documentation/platform/company-overview",
              "documentation/platform/stablecoin-issuance",
              "documentation/platform/stablecoin-orchestration",
              "documentation/platform/interoperability",
              "documentation/platform/tokenization",
              "documentation/platform/reserves",
              "documentation/platform/transfer-timing"
            ]
          },
          {
            "group": "Coverage",
            "pages": ["coverage/transfer-types", "coverage/value-types"]
          }
        ]
      },
      {
        "tab": "Tools",
        "groups": [
          {
            "group": "Commons",
            "pages": [
              "documentation/commons-stablecoin-format",
              "documentation/add-your-stablecoin",
              "documentation/commons-repo"
            ]
          },
          {
            "group": "Calculators",
            "pages": ["tools/calculators/stablecoin-calculators"]
          },
          {
            "group": "IO",
            "hidden": true,
            "pages": ["io/introduction"]
          },
          {
            "group": "MCP",
            "pages": ["mcp/api", "mcp/documentation"]
          }
        ]
      },
      {
        "tab": "API Docs",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "overview/introduction",
              "overview/quick-start",
              "overview/sandbox-and-testnet"
            ]
          },
          {
            "group": "Key concepts",
            "pages": [
              "key-concepts/api-concepts-overview",
              "key-concepts/authentication",
              "key-concepts/transfers",
              "key-concepts/accounts",
              "key-concepts/addresses",
              "key-concepts/external-bank-addresses",
              "key-concepts/automations",
              "key-concepts/financial-institutions",
              "key-concepts/idempotency"
            ]
          }
        ]
      },
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "How to",
            "pages": [
              "guides/how-to/get-your-account-id",
              "guides/how-to/get-your-address-ids",
              "guides/how-to/get-a-balance",
              "guides/how-to/add-external-destination"
            ]
          },
          {
            "group": "Workflows",
            "pages": [
              "guides/ach-on-ramp",
              "guides/fiat-to-stablecoin-onramp",
              "guides/stablecoin-to-fiat-offramp",
              "guides/stablecoin-to-stablecoin-swap",
              "guides/stablecoin-issuance",
              "guides/stablecoin-payouts",
              "guides/2nd-and-3rd-party-transfers",
              "guides/managed-accounts",
              "guides/self-custody-wallets",
              "guides/canton-token-standard",
              "guides/tokenization",
              "guides/canton-token-transfers-to-eoas"
            ]
          },
          {
            "group": "Integrations",
            "pages": ["guides/integrations/para-wallet"]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "API overview",
            "pages": ["api-reference/brale-introduction"]
          },
          {
            "group": "Endpoints",
            "pages": [
              "api-reference/brale/list-accounts",
              "api-reference/brale/create-account",
              "api-reference/brale/get-account",
              "api-reference/brale/list-transfers",
              "api-reference/brale/create-transfer",
              "api-reference/brale/get-transfer",
              "api-reference/brale/list-addresses",
              "api-reference/brale/create-address",
              "api-reference/brale/get-address-balance",
              "api-reference/brale/list-automations",
              "api-reference/brale/create-automations",
              "api-reference/brale/get-automations",
              "api-reference/brale/list-financial-institutions",
              "api-reference/brale/create-financial-institution",
              "api-reference/brale/get-financial-institution",
              "api-reference/brale/create-plaid-link-token",
              "api-reference/brale/register-financial-institution-account-via-plaid-and-return-address-id"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/images/brale/brale-logo-light.svg",
    "dark": "/images/brale/brale-logo-dark.svg"
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.brale.xyz"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/Brale-xyz"
    }
  },
  "openapi": "https://api.brale.xyz/openapi",
  "redirects": [
    {
      "source": "/docs/:slug*",
      "destination": "/documentation/:slug*"
    },
    {
      "source": "/reference/:slug*",
      "destination": "/api-reference/brale/:slug*"
    }
  ]
}
